PORT=3000
NODE_ENV=development

# Database (Prisma) — URL completa; local com Postgres na porta padrão:
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/cartwave_payments?schema=public

# Auth (JWT) — defina um segredo forte em produção; a aplicação exige JWT_SECRET fora de development
JWT_SECRET=change-me-in-development-only-use-strong-secret-in-production
JWT_EXPIRES_IN=1h
BCRYPT_SALT_ROUNDS=10

# Payment gateway (Mocks Server local em desenvolvimento)
PAYMENT_PROVIDER_URL=http://localhost:3110

# Webhook (provedor → esta API) — use o mesmo valor no Mocks Server ao disparar callbacks
# URL que o Mocks Server deve chamar após criar pagamento (opcional; se vazio, não dispara)
WEBHOOK_SECRET=1e30d43ddc063f0eeb9cccbcc7af05eb41331fdf36cb4e698ca498f3d12f45b3
MOCK_WEBHOOK_TARGET_URL=http://localhost:3000/api/v1/webhooks/payment
# Atraso (ms) antes do mock enviar o webhook (evita corrida com persistência de provider_tx_id na API)
MOCK_WEBHOOK_DELAY_MS=300

# SonarQube / SonarCloud (análise local: npm run sonar)
# SonarCloud: defina também SONAR_ORGANIZATION (chave da organização)
SONAR_TOKEN=
SONAR_HOST_URL=https://sonarcloud.io
SONAR_ORGANIZATION=
