{
  "name": "cartwave-payments",
  "version": "1.0.0",
  "description": "Payment API - Cartwave Code Challenge",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "test": "jest --runInBand --forceExit",
    "test:coverage": "jest --coverage --runInBand --forceExit",
    "test:unit": "jest tests/unit --runInBand --forceExit",
    "test:integration": "jest tests/integration --runInBand --forceExit",
    "prisma:generate": "prisma generate",
    "prisma:pull": "prisma db pull",
    "prisma:migrate:dev": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:studio": "prisma studio",
    "migrate": "prisma migrate deploy",
    "postinstall": "prisma generate",
    "coverage": "jest --coverage --runInBand --forceExit",
    "sonar": "sonar-scanner",
    "mock": "mocks-server",
    "mock:start": "mocks-server --no-plugins.inquirerCli.enabled"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@prisma/client-runtime-utils": "^7.8.0",
    "axios": "^1.6.0",
    "bcrypt": "^5.1.1",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-validator": "^7.0.1",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.20.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.0",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@mocks-server/main": "^4.1.0",
    "@testcontainers/postgresql": "^11.14.0",
    "jest": "^29.7.0",
    "nock": "^13.4.0",
    "nodemon": "^3.0.2",
    "prisma": "^7.8.0",
    "sonarqube-scanner": "^3.5.0",
    "supertest": "^6.3.3",
    "testcontainers": "^10.3.2"
  },
  "jest": {
    "testEnvironment": "node",
    "testTimeout": 60000,
    "collectCoverageFrom": [
      "src/**/*.js",
      "!src/index.js",
      "!src/domain/ports/**",
      "!src/infrastructure/providers/RealPaymentGateway.js"
    ],
    "coverageThreshold": {
      "global": {
        "lines": 80,
        "functions": 80,
        "branches": 80,
        "statements": 80
      }
    }
  }
}
