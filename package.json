{
  "name": "cartwave-payments",
  "version": "1.0.0",
  "description": "Payment API - Cartwave Code Challenge",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/index.js",
    "prestart": "npm run build",
    "dev": "tsx watch src/index.ts",
    "typecheck": "tsc --noEmit",
    "test": "NODE_OPTIONS='--experimental-vm-modules --max-old-space-size=4096' jest --runInBand --forceExit",
    "test:coverage": "NODE_OPTIONS='--experimental-vm-modules --max-old-space-size=4096' jest --coverage --runInBand --forceExit",
    "test:unit": "NODE_OPTIONS='--experimental-vm-modules --max-old-space-size=4096' jest tests/unit --runInBand --forceExit",
    "test:integration": "NODE_OPTIONS='--experimental-vm-modules --max-old-space-size=4096' jest tests/integration --runInBand --forceExit",
    "prisma:generate": "prisma generate",
    "prisma:pull": "prisma db pull",
    "prisma:migrate:dev": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:studio": "prisma studio",
    "migrate": "prisma migrate deploy",
    "postinstall": "prisma generate",
    "coverage": "NODE_OPTIONS='--experimental-vm-modules --max-old-space-size=4096' jest --coverage --runInBand --forceExit",
    "sonar": "sonar-scanner",
    "mock": "mocks-server",
    "mock:start": "mocks-server --no-plugins.inquirerCli.enabled"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@prisma/client-runtime-utils": "^7.8.0",
    "axios": "^1.6.0",
    "bcrypt": "^5.1.1",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-validator": "^7.0.1",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.20.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.0",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@mocks-server/main": "^4.1.0",
    "@testcontainers/postgresql": "^11.14.0",
    "@types/bcrypt": "^6.0.0",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.9.1",
    "@types/supertest": "^7.2.0",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "@types/uuid": "^10.0.0",
    "jest": "^29.7.0",
    "nock": "^13.4.0",
    "nodemon": "^3.0.2",
    "prisma": "^7.8.0",
    "sonarqube-scanner": "^3.5.0",
    "supertest": "^6.3.3",
    "testcontainers": "^10.3.2",
    "ts-jest": "^29.4.10",
    "ts-node": "^10.9.2",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3"
  }
}
